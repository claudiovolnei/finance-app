@using System.Globalization
@using Finance.Domain.Entities
@namespace Finance.Mobile.Components.Charts

<style>
    .category-chart { width:100%; }
    .category-row { display:flex; flex-direction:column; gap:6px; margin-bottom:12px; }
    .category-row-clickable { cursor:pointer; }
    .cat-info { display:flex; justify-content:space-between; font-size:0.9rem; margin-bottom:4px; }
    .bar-bg { background:rgba(0,0,0,0.04); height:18px; border-radius:10px; overflow:hidden; }
    .bar { height:100%; border-radius:10px 0 0 10px; }
    .no-data { text-align:center; color:rgba(0,0,0,0.45); padding:24px 0; }
</style>

@code {
    private readonly record struct CategoryChartItem(int? CategoryId, string Label, double Value, double Percentage, TransactionType Type);

    [Parameter] public int?[] CategoryIds { get; set; } = Array.Empty<int?>();
    [Parameter] public string[] Labels { get; set; } = Array.Empty<string>();
    [Parameter] public double[] Values { get; set; } = Array.Empty<double>();
    [Parameter] public double[] Percentages { get; set; } = Array.Empty<double>();
    [Parameter] public TransactionType[] Types { get; set; } = Array.Empty<TransactionType>();
    [Parameter] public string? EmptyMessage { get; set; } = "Sem dados";
    [Parameter] public EventCallback<CategoryChartSelection> OnCategoryClick { get; set; }

    private IEnumerable<CategoryChartItem> ChartItems
        => Labels.Select((label, i) => new CategoryChartItem(
            CategoryIds.Length > i ? CategoryIds[i] : null,
            label,
            Values.Length > i ? Values[i] : 0.0,
            Percentages.Length > i ? Percentages[i] : 0.0,
            Types.Length > i ? Types[i] : TransactionType.Expense));

    private List<CategoryChartItem> IncomeItems => ChartItems.Where(x => x.Type == TransactionType.Income).ToList();

    private List<CategoryChartItem> ExpenseItems => ChartItems.Where(x => x.Type == TransactionType.Expense).ToList();
}

<div class="category-chart">
    @if (Labels == null || Values == null || Values.Length == 0 || Labels.Length == 0)
    {
        <div class="no-data">@EmptyMessage</div>
    }
    else
    {
        @if (IncomeItems.Any())
        {
            <div class="cat-info">
                <div class="label"><strong>Recebidos</strong></div>
            </div>
            @foreach (var item in IncomeItems)
            {
                <div class="category-row category-row-clickable"
                     @onclick="async () => await HandleCategoryClick(item.Type, item.CategoryId, item.Label)">
                    <div class="cat-info">
                        <div class="label">@item.Label</div>
                        <div class="amount">@string.Format(new CultureInfo("pt-BR"), "{0:C}", item.Value)</div>
                    </div>
                    <div class="bar-bg">
                        <div class="bar" style="width:@item.Percentage%;background:#2e7d32"></div>
                    </div>
                </div>
            }
        }

        @if (ExpenseItems.Any())
        {
            <div class="cat-info" style="margin-top:12px;">
                <div class="label"><strong>Despesas</strong></div>
            </div>
            @foreach (var item in ExpenseItems)
            {
                <div class="category-row category-row-clickable"
                     @onclick="async () => await HandleCategoryClick(item.Type, item.CategoryId, item.Label)">
                    <div class="cat-info">
                        <div class="label">@item.Label</div>
                        <div class="amount">@string.Format(new CultureInfo("pt-BR"), "{0:C}", item.Value)</div>
                    </div>
                    <div class="bar-bg">
                        <div class="bar" style="width:@item.Percentage%;background:#c62828"></div>
                    </div>
                </div>
            }
        }
    }
</div>

@code {
    private async Task HandleCategoryClick(TransactionType type, int? categoryId, string label)
    {
        if (!OnCategoryClick.HasDelegate)
            return;

        await OnCategoryClick.InvokeAsync(new CategoryChartSelection(categoryId, label, type));
    }
}
