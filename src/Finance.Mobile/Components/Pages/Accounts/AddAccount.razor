@page "/accounts/add"
@using MudBlazor
@using Finance.Domain.Entities
@using Finance.Mobile.Services
@inject FinanceApiClient ApiClient
@inject NavigationManager Navigation
@inject TokenService TokenService

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4 management-page">
    <MudText Typo="Typo.h5" Class="mb-4 list-page-title">Nova conta</MudText>

    <MudForm>
        <MudStack Spacing="2">
            <MudTextField Label="Nome" @bind-Value="_name" Variant="Variant.Outlined" Required="true" />

            <MudSelect T="AccountType" Label="Tipo de conta" @bind-Value="_type" Variant="Variant.Outlined">
                <MudSelectItem Value="AccountType.Checking">Conta corrente</MudSelectItem>
                <MudSelectItem Value="AccountType.CreditCard">Cartão de crédito</MudSelectItem>
            </MudSelect>

            @if (_type == AccountType.CreditCard)
            {
                <MudSelect T="int?" Label="Conta corrente vinculada" @bind-Value="_parentAccountId" Variant="Variant.Outlined" Required="true">
                    @foreach (var account in _checkingAccounts)
                    {
                        <MudSelectItem T="int?" Value="@((int?)account.Id)">@account.Name</MudSelectItem>
                    }
                </MudSelect>

                @if (!_checkingAccounts.Any())
                {
                    <MudAlert Severity="Severity.Warning" Dense="true">Crie uma conta corrente antes de cadastrar um cartão de crédito.</MudAlert>
                }
            }
            else
            {
                <MudNumericField Label="Saldo inicial" @bind-Value="_initialBalance" Variant="Variant.Outlined" Required="true" Min="0" Adornment="Adornment.Start" AdornmentText="R$" />
            }

            <MudButtonGroup Class="mt-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Salvar" Disabled="@_saving">
                    @if (_saving)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ms-2">Salvando...</MudText>
                    }
                    else
                    {
                        <MudText>Salvar</MudText>
                    }
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancelar">Cancelar</MudButton>
            </MudButtonGroup>
        </MudStack>
    </MudForm>

    @if (!string.IsNullOrEmpty(_message))
    {
        <MudAlert Severity="@_alertSeverity" Class="mt-4">@_message</MudAlert>
    }
</MudContainer>

@code {
    private string _name = string.Empty;
    private decimal _initialBalance;
    private AccountType _type = AccountType.Checking;
    private int? _parentAccountId;
    private List<Account> _checkingAccounts = new();
    private string _message = string.Empty;
    private Severity _alertSeverity = Severity.Info;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        var token = await TokenService.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        try
        {
            ApiClient.SetBearerToken(token);
            var accounts = await ApiClient.GetAccountsAsync();
            _checkingAccounts = accounts.Where(a => a.Type == AccountType.Checking).OrderBy(a => a.Name).ToList();
            _parentAccountId = _checkingAccounts.FirstOrDefault()?.Id;
        }
        catch (Exception ex)
        {
            _message = $"Erro ao carregar contas: {ex.Message}";
            _alertSeverity = Severity.Error;
        }
    }

    private async Task Salvar()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _message = "Informe o nome da conta.";
            _alertSeverity = Severity.Warning;
            return;
        }

        if (_type == AccountType.CreditCard && !_parentAccountId.HasValue)
        {
            _message = "Selecione a conta corrente vinculada ao cartão.";
            _alertSeverity = Severity.Warning;
            return;
        }

        try
        {
            _saving = true;
            await ApiClient.CreateAccountAsync(_name.Trim(), _initialBalance, _type, _type == AccountType.CreditCard ? _parentAccountId : null);
            _message = "Conta criada com sucesso!";
            _alertSeverity = Severity.Success;
            await Task.Delay(800);
            Navigation.NavigateTo("/accounts");
        }
        catch (Exception ex)
        {
            _message = $"Erro ao criar conta: {ex.Message}";
            _alertSeverity = Severity.Error;
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancelar() => Navigation.NavigateTo("/accounts");
}
