@page "/accounts"
@using MudBlazor
@using Finance.Domain.Entities
@using Finance.Mobile.Services
@inject FinanceApiClient ApiClient
@inject NavigationManager Navigation
@inject TokenService TokenService
@inject AccountSelectionState AccountState

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 management-page">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="entity-page-header">
        <MudText Typo="Typo.h5" Class="list-page-title">Contas</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.Add" Class="new-entity-button" OnClick="NavigateToAdd">
            Nova
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
    }
    else if (_accounts.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Dense="true">Nenhuma conta cadastrada.</MudAlert>
    }
    else
    {
        <MudGrid GutterSize="GutterSize.Small">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.subtitle2" Class="mb-3">Contas correntes</MudText>
                    @if (!CheckingAccounts.Any())
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">Nenhuma conta corrente cadastrada.</MudAlert>
                    }
                    else
                    {
                        <MudList T="Account" Dense="true" Class="pa-0">
                            @foreach (var account in CheckingAccounts)
                            {
                                @AccountRow(account)
                            }
                        </MudList>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.subtitle2" Class="mb-3">Cartões de crédito</MudText>
                    @if (!CreditCardAccounts.Any())
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">Nenhum cartão cadastrado.</MudAlert>
                    }
                    else
                    {
                        <MudList T="Account" Dense="true" Class="pa-0">
                            @foreach (var account in CreditCardAccounts)
                            {
                                @AccountRow(account)
                            }
                        </MudList>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }

    @if (!string.IsNullOrEmpty(_message))
    {
        <MudAlert Severity="@_alertSeverity" Dense="true" Class="mt-3">@_message</MudAlert>
    }
</MudContainer>

@code {
    private List<Account> _accounts = new();
    private bool _loading = true;
    private string _message = string.Empty;
    private Severity _alertSeverity = Severity.Info;

    private List<Account> CheckingAccounts => _accounts.Where(a => a.Type == AccountType.Checking).OrderBy(a => a.Name).ToList();
    private List<Account> CreditCardAccounts => _accounts.Where(a => a.Type == AccountType.CreditCard).OrderBy(a => a.Name).ToList();

    protected override async Task OnInitializedAsync()
    {
        var token = await TokenService.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        ApiClient.SetBearerToken(token);
        await LoadAccounts();
    }

    private RenderFragment AccountRow(Account account) => @<>
        <MudListItem Class="px-0">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width:100%;">
                <MudStack Spacing="0" Style="min-width:0;">
                    <MudText Typo="Typo.body2" Class="list-primary-text">@account.Name</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary list-secondary-text">@GetSubtitle(account)</MudText>
                </MudStack>

                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@(account.Type == AccountType.CreditCard ? Color.Error : Color.Info)">@GetTypeLabel(account.Type)</MudChip>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => NavigateToEdit(account.Id))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteAccount(account.Id))" />
                </MudStack>
            </MudStack>
        </MudListItem>
        <MudDivider />
    </>;

    private async Task LoadAccounts()
    {
        try
        {
            _loading = true;
            _accounts = await ApiClient.GetAccountsAsync();
            AccountState.SetAccounts(_accounts);
        }
        catch (Exception ex)
        {
            _message = $"Erro ao carregar contas: {ex.Message}";
            _alertSeverity = Severity.Error;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetTypeLabel(AccountType type) => type == AccountType.CreditCard ? "Cartão" : "Conta";

    private string GetSubtitle(Account account) => account.Type == AccountType.CreditCard
        ? $"Vinculado a: {_accounts.FirstOrDefault(a => a.Id == account.ParentAccountId)?.Name ?? "-"}"
        : $"Saldo inicial: {account.InitialBalance.ToString("C", new System.Globalization.CultureInfo("pt-BR"))}";

    private void NavigateToAdd() => Navigation.NavigateTo("/accounts/add");
    private void NavigateToEdit(int id) => Navigation.NavigateTo($"/accounts/edit/{id}");

    private async Task DeleteAccount(int id)
    {
        try
        {
            await ApiClient.DeleteAccountAsync(id);
            _message = "Conta excluída com sucesso!";
            _alertSeverity = Severity.Success;
            await LoadAccounts();
        }
        catch (Exception ex)
        {
            _message = $"Erro ao excluir conta: {ex.Message}";
            _alertSeverity = Severity.Error;
        }
    }
}
