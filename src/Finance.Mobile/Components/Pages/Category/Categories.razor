@page "/categories"
@using MudBlazor
@using Finance.Domain.Entities
@using Finance.Mobile.Services
@inject FinanceApiClient ApiClient
@inject NavigationManager Navigation
@inject TokenService TokenService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 management-page">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="entity-page-header">
        <MudText Typo="Typo.h5" Class="list-page-title">Categorias</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.Add" Class="new-entity-button" OnClick="NavigateToAdd">
            Nova
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
    }
    else if (_categories == null || !_categories.Any())
    {
        <MudAlert Severity="Severity.Info" Dense="true">Nenhuma categoria encontrada.</MudAlert>
    }
    else
    {
        <MudPaper Class="pa-4 category-list-surface" Elevation="1">
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-3">
                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="category-summary-chip">
                    Total: @_categories!.Count
                </MudChip>
                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Class="category-summary-chip">
                    Exibindo: @FilteredCategories.Count
                </MudChip>
            </MudStack>

            <MudGrid Class="mb-3" AlignItems="AlignItems.Center">
                <MudItem xs="12" sm="8">
                    <MudTextField @bind-Value="SearchTerm"
                                  Label="Buscar categoria"
                                  Placeholder="Digite o nome da categoria"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string" Label="Tipo" @bind-Value="TypeFilter" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Tune">
                        <MudSelectItem Value="@("all")">Todos</MudSelectItem>
                        <MudSelectItem Value="@("income")">Receita</MudSelectItem>
                        <MudSelectItem Value="@("expense")">Despesa</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2" Wrap="Wrap.Wrap">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@FilteredCategories.Count categorias encontradas</MudText>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Itens por página</MudText>
                    <MudSelect T="int" Value="@_pageSize" ValueChanged="OnPageSizeChanged" Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:88px;">
                        <MudSelectItem Value="10">10</MudSelectItem>
                        <MudSelectItem Value="20">20</MudSelectItem>
                        <MudSelectItem Value="50">50</MudSelectItem>
                    </MudSelect>
                </MudStack>
            </MudStack>

            @if (!PagedCategories.Any())
            {
                <MudAlert Severity="Severity.Info" Dense="true">Nenhuma categoria para os filtros selecionados.</MudAlert>
            }
            else
            {
                <MudList T="Category" Dense="true" Class="pa-0">
                    @foreach (var category in PagedCategories)
                    {
                        <MudListItem Class="px-0">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width:100%; gap:12px;">
                                <MudStack Spacing="0" Style="min-width:0;">
                                    <MudText Typo="Typo.body2" Class="list-primary-text">@category.Name</MudText>
                                </MudStack>

                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudChip T="string"
                                             Color="@GetTransactionColor(category.Type)"
                                             Variant="Variant.Text"
                                             Size="Size.Small">
                                        @(category.Type == TransactionType.Income ? "Receita" : "Despesa")
                                    </MudChip>
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => NavigateToEdit(category.Id))" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteCategory(category.Id))" />
                                </MudStack>
                            </MudStack>
                        </MudListItem>
                        <MudDivider />
                    }
                </MudList>

                <MudStack Row="true" Justify="Justify.Center" Class="mt-3">
                    <MudPagination Count="@TotalPages" @bind-Selected="_currentPage" Color="Color.Primary" Size="Size.Small" />
                </MudStack>
            }
        </MudPaper>
    }

    @if (!string.IsNullOrEmpty(_message))
    {
        <MudAlert Severity="@_alertSeverity" Dense="true" Class="mt-3">@_message</MudAlert>
    }
</MudContainer>

@code {
    private List<Category>? _categories;
    private bool _loading = true;
    private string _message = "";
    private Severity _alertSeverity = Severity.Info;
    private string _searchTerm = string.Empty;
    private string _typeFilter = "all";
    private int _currentPage = 1;
    private int _pageSize = 10;

    private string SearchTerm
    {
        get => _searchTerm;
        set
        {
            _searchTerm = value;
            _currentPage = 1;
        }
    }

    private string TypeFilter
    {
        get => _typeFilter;
        set
        {
            _typeFilter = value;
            _currentPage = 1;
        }
    }

    private List<Category> FilteredCategories =>
        _categories?
            .Where(c => string.IsNullOrWhiteSpace(_searchTerm) || c.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
            .Where(c => IsTypeMatch(c.Type))
            .OrderBy(c => c.Type)
            .ThenBy(c => c.Name)
            .ToList() ?? new List<Category>();

    private List<Category> PagedCategories =>
        FilteredCategories
            .Skip((_currentPage - 1) * _pageSize)
            .Take(_pageSize)
            .ToList();

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)FilteredCategories.Count / _pageSize));

    private bool IsTypeMatch(TransactionType type) =>
        _typeFilter switch
        {
            "income" => type == TransactionType.Income,
            "expense" => type == TransactionType.Expense,
            _ => true
        };

    private Color GetTransactionColor(TransactionType type) =>
        type == TransactionType.Income ? Color.Success : Color.Error;

    protected override async Task OnInitializedAsync()
    {
        var token = await TokenService.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("/login");
            return;
        }
        await LoadCategories();
    }

    private Task OnPageSizeChanged(int pageSize)
    {
        _pageSize = pageSize;
        _currentPage = 1;
        return Task.CompletedTask;
    }

    private async Task LoadCategories()
    {
        try
        {
            _loading = true;
            _categories = await ApiClient.GetCategoriesAsync();
            _currentPage = 1;
        }
        catch (UnauthorizedAccessException)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        catch (Exception ex)
        {
            _message = $"Erro ao carregar categorias: {ex.Message}";
            _alertSeverity = Severity.Error;
        }
        finally
        {
            _loading = false;
        }
    }

    private async void NavigateToAdd()
    {
        var token = await TokenService.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("/login");
            return;
        }
        Navigation.NavigateTo("/categories/add");
    }

    private void NavigateToEdit(int id)
    {
        _ = EnsureAndNavigateEdit(id);
    }

    private async Task EnsureAndNavigateEdit(int id)
    {
        var token = await TokenService.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("/login");
            return;
        }
        Navigation.NavigateTo($"/categories/edit/{id}");
    }

    private async Task DeleteCategory(int id)
    {
        var token = await TokenService.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        try
        {
            await ApiClient.DeleteCategoryAsync(id);
            _message = "Categoria excluída com sucesso!";
            _alertSeverity = Severity.Success;
            await LoadCategories();
        }
        catch (UnauthorizedAccessException)
        {
            Navigation.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            _message = $"Erro ao excluir categoria: {ex.Message}";
            _alertSeverity = Severity.Error;
        }
    }
}
