@page "/categories"
@using MudBlazor
@using Finance.Domain.Entities
@using Finance.Mobile.Services
@inject FinanceApiClient ApiClient
@inject NavigationManager Navigation
@inject TokenService TokenService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 management-page">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="entity-page-header">
        <MudText Typo="Typo.h5" Class="list-page-title">Categorias</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.Add" Class="new-entity-button" OnClick="NavigateToAdd">
            Nova
        </MudButton>
    </MudStack>

    <MudStack Row="true" AlignItems="AlignItems.End" Spacing="2" Class="mb-3">
        <MudTextField Label="Filtrar por usuário" Variant="Variant.Outlined" @bind-Value="_ownerUserIdFilter" Immediate="true" Placeholder="ID do usuário" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyUserFilter">Filtrar</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="ResetUserFilter">Limpar</MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
    }
    else if (_categories == null || !_categories.Any())
    {
        <MudAlert Severity="Severity.Info" Dense="true">Nenhuma categoria encontrada.</MudAlert>
    }
    else
    {
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2">@_categories.Count categorias</MudText>
            <MudList T="Category" Dense="true" Class="pa-0">
                @foreach (var category in _categories)
                {
                    <MudListItem Class="px-0">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width:100%;">
                            <MudText Typo="Typo.body2" Class="list-primary-text">@category.Name</MudText>
                            <MudChip T="string"
                                     Color="@GetTransactionColor(@category.Type)"
                                     Variant="Variant.Filled"
                                     Size="Size.Small">
                                @(category.Type == TransactionType.Income ? "Receita" : "Despesa")
                            </MudChip>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => NavigateToEdit(category.Id))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteCategory(category.Id))" />
                            </MudStack>
                        </MudStack>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>
        </MudPaper>
    }

    @if (!string.IsNullOrEmpty(_message))
    {
        <MudAlert Severity="@_alertSeverity" Dense="true" Class="mt-3">@_message</MudAlert>
    }
</MudContainer>

@code {
    private List<Category>? _categories;
    private bool _loading = true;
    private string _message = "";
    private Severity _alertSeverity = Severity.Info;
    private string _ownerUserIdFilter = "";
    private int? _loggedUserId;

    private Color GetTransactionColor(TransactionType type) =>
        type == TransactionType.Income ? Color.Success : Color.Error;

    protected override async Task OnInitializedAsync()
    {
        var token = await TokenService.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("/login");
            return;
        }
        _loggedUserId = await TokenService.GetUserIdAsync();
        _ownerUserIdFilter = _loggedUserId?.ToString() ?? string.Empty;
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        try
        {
            _loading = true;
            int? ownerUserId = null;
            if (!string.IsNullOrWhiteSpace(_ownerUserIdFilter))
            {
                if (!int.TryParse(_ownerUserIdFilter, out var parsedOwnerUserId))
                    throw new Exception("Informe um ID de usuário válido para o filtro.");

                ownerUserId = parsedOwnerUserId;
            }

            _categories = await ApiClient.GetCategoriesAsync(ownerUserId);
        }
        catch (UnauthorizedAccessException)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        catch (Exception ex)
        {
            _message = $"Erro ao carregar categorias: {ex.Message}";
            _alertSeverity = Severity.Error;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ApplyUserFilter()
    {
        await LoadCategories();
    }

    private async Task ResetUserFilter()
    {
        _ownerUserIdFilter = _loggedUserId?.ToString() ?? string.Empty;
        await LoadCategories();
    }

    private async void NavigateToAdd()
    {
        var token = await TokenService.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("/login");
            return;
        }
        Navigation.NavigateTo("/categories/add");
    }

    private void NavigateToEdit(int id)
    {
        _ = EnsureAndNavigateEdit(id);
    }

    private async Task EnsureAndNavigateEdit(int id)
    {
        var token = await TokenService.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("/login");
            return;
        }
        Navigation.NavigateTo($"/categories/edit/{id}");
    }

    private async Task DeleteCategory(int id)
    {
        var token = await TokenService.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        try
        {
            await ApiClient.DeleteCategoryAsync(id);
            _message = "Categoria excluída com sucesso!";
            _alertSeverity = Severity.Success;
            await LoadCategories();
        }
        catch (UnauthorizedAccessException)
        {
            Navigation.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            _message = $"Erro ao excluir categoria: {ex.Message}";
            _alertSeverity = Severity.Error;
        }
    }
}
