@page "/"
@implements IDisposable
@using Finance.Mobile.Components.Charts
@using Finance.Mobile.Services
@using Finance.Domain.Entities

<MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
    <MonthYearNavigator CurrentLabel="@GetCurrentFilterLabel()" OnPrevious="PrevMonth" OnNext="NextMonth" />
    <MudGrid GutterSize="GutterSize.Small" AlignItems="Center">
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-4 card-center" Elevation="1">
                <MudText Typo="Typo.subtitle1">Saldo Atual</MudText>
                <MudText Typo="Typo.h5" Class="fluid-value" Color="_summary?.Balance > 0 ? Color.Success : Color.Error">@(_summary is null ? "-" : string.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C}", _summary.Balance))</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3" md="4">
            <MudPaper Class="pa-4 card-center" Elevation="1">
                <MudText Typo="Typo.subtitle1">Receitas</MudText>
                <MudText Typo="Typo.h5" Class="fluid-value" Color="Color.Success">@(_summary is null ? "-" : string.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C}", _summary.TotalIncome))</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3" md="4">
            <MudPaper Class="pa-4 card-center" Elevation="1">
                <MudText Typo="Typo.subtitle1">Despesas</MudText>
                <MudText Typo="Typo.h5" Class="fluid-value" Color="Color.Error">@(_summary is null ? "-" : string.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C}", _summary.TotalExpense))</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" class="mt-3">
            <MudPaper Class="pa-4 credit-card-debt-card" Elevation="1">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2">Dívida do cartão</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Total acumulado dos cartões vinculados no período.</MudText>
                    </MudStack>
                    <MudChip T="string" Color="Color.Error" Variant="Variant.Filled" Size="Size.Small">Cartões</MudChip>
                </MudStack>
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.End" Class="mt-4">
                    <MudText Typo="Typo.h4" Class="credit-card-debt-value">@(_summary is null ? "-" : string.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C}", _summary.TotalCreditCardDebt))</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@(_summary?.CreditCardExpenses.Count ?? 0) cartão(ões) com movimentação</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6" class="mt-3">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.subtitle1" Class="mb-2">Categorias por tipo</MudText>
                <CategoryBarChart CategoryIds="@_chartCategoryIds" Labels="@_chartLabels" Values="@_chartDataRaw" Percentages="@_chartPercentages" Types="@_chartTypes" EmptyMessage="Sem dados" OnCategoryClick="OpenCategoryDialogAsync" />
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6" class="mt-3">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.subtitle1" Class="mb-2">Gastos do cartão</MudText>
                <CreditCardExpenseBarChart Data="@(_summary?.CreditCardExpenses ?? new List<CreditCardExpenseSummaryDto>())" />
            </MudPaper>
        </MudItem>

        <MudItem xs="12" class="mt-3">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.subtitle1" Class="mb-2">Últimos Lançamentos</MudText>

                @if (_summary is null)
                {
                    <MudSkeleton Height="44px" Class="mb-2" />
                    <MudSkeleton Height="44px" Class="mb-2" />
                    <MudSkeleton Height="44px" />
                }
                else if (!_summary.LatestTransactions.Any())
                {
                    <MudAlert Severity="Severity.Info" Dense="true">Sem lançamentos no período.</MudAlert>
                }
                else
                {
                    @if (_latestIncomeTransactions.Any())
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">Créditos</MudText>
                        <MudList T="TransactionSummaryDto" Dense="true" Class="pa-0 mb-3">
                            @foreach (var tx in _latestIncomeTransactions)
                            {
                                @LatestTransactionRow(tx)
                            }
                        </MudList>
                    }

                    @if (_latestExpenseTransactions.Any())
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">Débitos</MudText>
                        <MudList T="TransactionSummaryDto" Dense="true" Class="pa-0">
                            @foreach (var tx in _latestExpenseTransactions)
                            {
                                @LatestTransactionRow(tx)
                            }
                        </MudList>
                    }
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@if (_isCategoryPanelVisible)
{
    <div class="transaction-detail-overlay" @onclick="CloseCategoryExpenseDialogAsync">
        <MudPaper Class="@GetCategoryPanelClass()" Elevation="6" @onclick:stopPropagation="true">
            <MudStack Spacing="3">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudText Typo="Typo.h6">@_categoryDialogTitle</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseCategoryExpenseDialogAsync" />
                </MudStack>
                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2">Total no mês: <span style="color:@(_categoryDialogType == TransactionType.Income ? "#2e7d32" : "#c62828")">@string.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C}", _categoryDialogTotal)</span></MudText>

                @if (!_categoryDialogTransactions.Any())
                {
                    <MudAlert Severity="Severity.Info" Dense="true">Nenhum lançamento nesta categoria no período.</MudAlert>
                }
                else
                {
                    <MudList T="TransactionSummaryDto" Dense="true" Class="pa-0">
                        @foreach (var tx in _categoryDialogTransactions)
                        {
                            @LatestTransactionRow(tx)
                        }
                    </MudList>
                }
            </MudStack>
        </MudPaper>
    </div>
}

@if (_isTransactionPanelVisible && _selectedTransaction is not null)
{
    <div class="transaction-detail-overlay" @onclick="CloseTransactionDialogAsync">
        <MudPaper Class="@GetTransactionPanelClass()" Elevation="6" @onclick:stopPropagation="true">
            <MudStack Spacing="3">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Class="transaction-detail-subtitle">Resumo do lançamento</MudText>
                    </MudStack>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" Size="Size.Small" OnClick="CloseTransactionDialogAsync" />
                </MudStack>

                <MudPaper Class="transaction-highlight-card" Elevation="0">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Valor da transação</MudText>
                            <MudText Typo="Typo.h5" Color="@GetTransactionColor(_selectedTransaction.Type)">@string.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C}", _selectedTransaction.Amount)</MudText>
                        </MudStack>
                        <MudChip T="string" Color="@GetTransactionColor(_selectedTransaction.Type)" Variant="Variant.Filled" Size="Size.Small">@(_selectedTransaction.Type == TransactionType.Income ? "Receita" : "Despesa")</MudChip>
                    </MudStack>
                </MudPaper>

                <MudGrid Class="transaction-detail-grid" GutterSize="GutterSize.Small">
                    <MudItem xs="12" sm="6">
                        <MudPaper Class="transaction-detail-item" Elevation="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Conta do lançamento</MudText>
                            <MudText Typo="Typo.body1">@_selectedTransaction.AccountName</MudText>
                        </MudPaper>
                    </MudItem>
                    @if (_selectedTransaction.IsCreditCardExpense)
                    {
                        <MudItem xs="12" sm="6">
                            <MudPaper Class="transaction-detail-item" Elevation="0">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Conta vinculada</MudText>
                                <MudText Typo="Typo.body1">@(_selectedTransaction.ParentAccountName ?? "-")</MudText>
                            </MudPaper>
                        </MudItem>
                    }
                    <MudItem xs="12" sm="6">
                        <MudPaper Class="transaction-detail-item" Elevation="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Categoria</MudText>
                            <MudText Typo="Typo.body1">@_selectedTransaction.CategoryName</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudPaper Class="transaction-detail-item" Elevation="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Data</MudText>
                            <MudText Typo="Typo.body1">@_selectedTransaction.Date.ToString("dd/MM/yyyy")</MudText>
                        </MudPaper>
                    </MudItem>
                    @if (!_selectedTransaction.TransactionAccountName.Equals("N/A"))
                    {
                        <MudItem xs="12" sm="6">
                            <MudPaper Class="transaction-detail-item" Elevation="0">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@(_selectedTransaction.Type == TransactionType.Income ? "Recebido da:" : "Enviado para:")</MudText>
                                <MudText Typo="Typo.body1">@_selectedTransaction.TransactionAccountName</MudText>
                            </MudPaper>
                        </MudItem>
                    }
                    <MudItem xs="12">
                        <MudPaper Class="transaction-detail-item" Elevation="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Descrição</MudText>
                            <MudText Typo="Typo.body1">@(string.IsNullOrWhiteSpace(_selectedTransaction.Description) ? "Sem descrição informada" : _selectedTransaction.Description)</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudDivider />
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Referência da transação #@_selectedTransaction.Id</MudText>
            </MudStack>
        </MudPaper>
    </div>
}

@code {
    [Inject] public FinanceApiClient Api { get; set; } = default!;
    [Inject] public TokenService TokenService { get; set; } = default!;
    [Inject] public AccountSelectionState AccountState { get; set; } = default!;
    [Inject] public NavigationManager Navigation { get; set; } = default!;

    private DashboardSummaryDto? _summary;
    private int?[] _chartCategoryIds = Array.Empty<int?>();
    private string[] _chartLabels = Array.Empty<string>();
    private double[] _chartDataRaw = Array.Empty<double>();
    private double[] _chartPercentages = Array.Empty<double>();
    private TransactionType[] _chartTypes = Array.Empty<TransactionType>();
    private List<TransactionSummaryDto> _latestIncomeTransactions = new();
    private List<TransactionSummaryDto> _latestExpenseTransactions = new();
    private bool _isCategoryDialogOpen;
    private bool _isCategoryPanelVisible;
    private string _categoryDialogTitle = "";
    private decimal _categoryDialogTotal;
    private List<TransactionSummaryDto> _categoryDialogTransactions = new();
    private TransactionType _categoryDialogType = TransactionType.Expense;
    private int? _filterYear;
    private int? _filterMonth;
    private DateTime _current = DateTime.Now;
    private TransactionSummaryDto? _selectedTransaction;
    private bool _isTransactionDialogOpen;
    private bool _isTransactionPanelVisible;
    private const int TransactionPanelAnimationMs = 260;

    protected override async Task OnInitializedAsync()
    {
        AccountState.OnChange += HandleAccountChanged;

        var token = await TokenService.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        Api.SetBearerToken(token);
        _filterYear = _current.Year;
        _filterMonth = _current.Month;

        await LoadSummaryAsync();
    }

    private RenderFragment LatestTransactionRow(TransactionSummaryDto tx) => @<>
        <MudListItem Class="px-0" Button="true" OnClick="@(() => OpenTransactionDialog(tx))">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width:100%;">
                <MudStack Spacing="0" Style="min-width:0;">
                    <MudText Typo="Typo.body2" Class="list-primary-text">@tx.CategoryName</MudText>
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary list-secondary-text">@tx.Date.ToString("dd/MM/yyyy")</MudText>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@(tx.IsCreditCardExpense ? Color.Error : Color.Info)">@GetAccountChipLabel(tx)</MudChip>
                    </MudStack>
                </MudStack>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@tx.AccountName</MudText>
                    <MudChip T="string" Color="@(tx.Type == TransactionType.Income ? Color.Success : Color.Error)" Variant="Variant.Text" Size="Size.Small">@(tx.Type == TransactionType.Income ? "Crédito" : "Débito")</MudChip>
                    <MudText Typo="Typo.body2" Class="list-value-text" Color="@(tx.Type == TransactionType.Income ? Color.Success : Color.Error)">@string.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C}", tx.Amount)</MudText>
                </MudStack>
            </MudStack>
        </MudListItem>
        <MudDivider />
    </>;

    private string GetCurrentFilterLabel() => _current.ToString("MMMM yyyy", new System.Globalization.CultureInfo("pt-BR"));

    private async Task PrevMonth()
    {
        _current = _current.AddMonths(-1);
        _filterYear = _current.Year;
        _filterMonth = _current.Month;
        await LoadSummaryAsync();
    }

    private async Task NextMonth()
    {
        _current = _current.AddMonths(1);
        _filterYear = _current.Year;
        _filterMonth = _current.Month;
        await LoadSummaryAsync();
    }

    private async Task LoadSummaryAsync()
    {
        try
        {
            var dto = await Api.GetDashboardSummaryAsync(_filterYear, _filterMonth, AccountState.SelectedAccountId);
            if (dto == null)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            _summary = dto;
            _chartCategoryIds = dto.Categories.Select(c => c.CategoryId).ToArray();
            _chartLabels = dto.Categories.Select(c => c.Name).ToArray();
            _chartDataRaw = dto.Categories.Select(c => (double)c.Amount).ToArray();
            var totalIncome = dto.TotalIncome;
            var totalExpense = dto.TotalExpense;
            _chartPercentages = dto.Categories.Select(c =>
            {
                var totalByType = c.Type == TransactionType.Income ? totalIncome : totalExpense;
                return totalByType <= 0 ? 0d : (double)(c.Amount / totalByType * 100m);
            }).ToArray();
            _chartTypes = dto.Categories.Select(c => c.Type).ToArray();
            _latestIncomeTransactions = dto.LatestTransactions.Where(t => t.Type == TransactionType.Income).OrderByDescending(t => t.Date).ThenByDescending(t => t.Id).ToList();
            _latestExpenseTransactions = dto.LatestTransactions.Where(t => t.Type == TransactionType.Expense).OrderByDescending(t => t.Date).ThenByDescending(t => t.Id).ToList();
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // ignore
        }
    }

    private async void HandleAccountChanged()
    {
        await InvokeAsync(async () =>
        {
            _current = DateTime.Now;
            _filterYear = _current.Year;
            _filterMonth = _current.Month;
            await LoadSummaryAsync();
            StateHasChanged();
        });
    }

    private string GetAccountChipLabel(TransactionSummaryDto transaction) => transaction.IsCreditCardExpense
        ? $"Cartão · {transaction.ParentAccountName}"
        : "Conta corrente";

    private void OpenTransactionDialog(TransactionSummaryDto transaction)
    {
        _selectedTransaction = transaction;
        _isTransactionPanelVisible = true;
        _isTransactionDialogOpen = true;
    }

    private async Task CloseTransactionDialogAsync()
    {
        _isTransactionDialogOpen = false;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(TransactionPanelAnimationMs);
        _isTransactionPanelVisible = false;
        _selectedTransaction = null;
    }

    private string GetTransactionPanelClass() => _isTransactionDialogOpen ? "transaction-detail-dialog transaction-detail-dialog-open" : "transaction-detail-dialog transaction-detail-dialog-close";
    private Color GetTransactionColor(TransactionType type) => type == TransactionType.Income ? Color.Success : Color.Error;

    private async Task OpenCategoryDialogAsync(CategoryChartSelection selection)
    {
        try
        {
            var details = await Api.GetCategoryTransactionsAsync(selection.Type, selection.CategoryId, _filterYear, _filterMonth, AccountState.SelectedAccountId);
            if (details is null)
                return;

            _categoryDialogTitle = $"Lançamentos em {details.Title}";
            _categoryDialogTotal = details.TotalAmount;
            _categoryDialogType = details.Type;
            _categoryDialogTransactions = details.Transactions.OrderBy(t => t.Date).ThenBy(t => t.Id).ToList();
            _isCategoryPanelVisible = true;
            _isCategoryDialogOpen = true;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // ignore
        }
    }

    private async Task CloseCategoryExpenseDialogAsync()
    {
        _isCategoryDialogOpen = false;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(TransactionPanelAnimationMs);
        _isCategoryPanelVisible = false;
        _categoryDialogTransactions = new();
    }

    private string GetCategoryPanelClass() => _isCategoryDialogOpen ? "transaction-detail-dialog transaction-detail-dialog-open" : "transaction-detail-dialog transaction-detail-dialog-close";

    public void Dispose() => AccountState.OnChange -= HandleAccountChanged;
}
