@page "/transactions/edit/{Id:int}"
@implements IDisposable
@using MudBlazor
@using Finance.Domain.Entities
@using Finance.Mobile.Services
@inject FinanceApiClient ApiClient
@inject NavigationManager Navigation
@inject TokenService TokenService

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4 management-page">
    <MudText Typo="Typo.h5" Class="mb-4 list-page-title">Editar lançamento</MudText>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
    }
    else if (_transaction == null)
    {
        <MudAlert Severity="Severity.Error">Lançamento não encontrada.</MudAlert>
    }
    else
    {
        <MudForm>
            <MudSwitch T="bool" @bind-Value="_isTransfer" Color="Color.Primary" Label="É transferência?" Class="mt-2" />

            @if (_isTransfer)
            {
                <MudSelect T="TransferDirection" Label="Direção" @bind-Value="_transferDirection" Variant="Variant.Outlined" Required="true" Class="mt-4">
                    <MudSelectItem Value="TransferDirection.Send">Enviar</MudSelectItem>
                    <MudSelectItem Value="TransferDirection.Receive">Receber</MudSelectItem>
                </MudSelect>

                <MudSelect T="int" Label="Conta de transferência" Value="_transferAccountId" ValueChanged="OnTransferAccountChanged" Variant="Variant.Outlined" Required="true" Class="mt-4">
                    @foreach (var account in _availableAccounts)
                    {
                        <MudSelectItem Value="@account.Id">@account.Name</MudSelectItem>
                    }
                </MudSelect>

                <MudText Typo="Typo.body2" Class="mt-2 mud-text-secondary">
                    Saldo da conta selecionada: @string.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C}", _selectedTransferAccountBalance)
                </MudText>
            }
            else
            {
                <MudSelect T="int" Label="Categoria" @bind-Value="_categoryId" Variant="Variant.Outlined" Required="true">
                    @foreach (var category in _categories)
                    {
                        <MudSelectItem Value="@category.Id">@category.Name</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="TransactionType" Label="Tipo" @bind-Value="_type" Variant="Variant.Outlined" Required="true" Class="mt-4">
                    <MudSelectItem Value="TransactionType.Income">Receita</MudSelectItem>
                    <MudSelectItem Value="TransactionType.Expense">Despesa</MudSelectItem>
                </MudSelect>
            }

            <MudTextField Label="Valor" @bind-Value="_amountText" Variant="Variant.Outlined" Required="true" Class="mt-4"
                          Adornment="Adornment.Start" AdornmentText="R$" @onblur="FormatAmount" @oninput="OnAmountInput" />

            <MudDatePicker Label="Data" Date="@_date" DateChanged="(date) => _date = date ?? DateTime.Now" Variant="Variant.Outlined" Required="true" Class="mt-4" />
            <MudTextField Label="Descrição" @bind-Value="_description" Variant="Variant.Outlined" Lines="3" Class="mt-4" />

            <MudButtonGroup Class="mt-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Salvar" Disabled="@_saving">Salvar</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancelar">Cancelar</MudButton>
            </MudButtonGroup>
        </MudForm>
    }

    @if (!string.IsNullOrEmpty(_message))
    {
        <MudAlert Severity="@_alertSeverity" Class="mt-4">@_message</MudAlert>
    }
</MudContainer>

@code {
    private enum TransferDirection { Send, Receive }

    [Parameter] public int Id { get; set; }
    [Inject] public AccountSelectionState AccountState { get; set; } = default!;

    private List<Category> _categories = new();
    private List<Account> _availableAccounts = new();
    private Finance.Mobile.Services.TransactionDto? _transaction;
    private int _categoryId;
    private int _transferAccountId;
    private decimal _selectedTransferAccountBalance;
    private decimal _amount;
    private string _amountText = "0,00";
    private DateTime _date = DateTime.Now;
    private string _description = "";
    private TransactionType _type = TransactionType.Expense;
    private bool _isTransfer;
    private TransferDirection _transferDirection = TransferDirection.Send;
    private string _message = "";
    private Severity _alertSeverity = Severity.Info;
    private bool _loading = true;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        AccountState.OnChange += HandleAccountChanged;
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _categories = await ApiClient.GetCategoriesAsync();
        _transaction = await ApiClient.GetTransactionByIdAsync(Id);
        await LoadTransferAccounts();

        if (_transaction != null)
        {
            _isTransfer = _transaction.TransferAccountId.HasValue;
            _categoryId = _transaction.CategoryId ?? 0;
            _transferAccountId = _transaction.TransferAccountId ?? 0;
            _amount = _transaction.Amount;
            _amountText = _amount.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"));
            _date = _transaction.Date;
            _description = _transaction.Description ?? string.Empty;
            _type = _transaction.Type;
            _transferDirection = _type == TransactionType.Expense ? TransferDirection.Send : TransferDirection.Receive;
            if (_transferAccountId > 0) await LoadSelectedTransferAccountBalance();
        }

        _loading = false;
    }

    private async Task LoadTransferAccounts()
    {
        var currentAccountId = AccountState.SelectedAccountId ?? 0;
        var accounts = await ApiClient.GetAccountsAsync();
        _availableAccounts = accounts.Where(a => a.Id != currentAccountId).ToList();
        if (_transferAccountId == 0 && _availableAccounts.Any())
            _transferAccountId = _availableAccounts.First().Id;
    }

    private async Task OnTransferAccountChanged(int value)
    {
        _transferAccountId = value;
        await LoadSelectedTransferAccountBalance();
    }

    private async Task LoadSelectedTransferAccountBalance()
    {
        var account = await ApiClient.GetAccountByIdAsync(_transferAccountId);
        if (account is null) return;
        var tx = await ApiClient.GetTransactionsAsync(accountId: _transferAccountId);
        var delta = tx.Sum(t => t.Type == TransactionType.Income ? t.Amount : -t.Amount);
        _selectedTransferAccountBalance = account.InitialBalance + delta;
    }

    private async Task Salvar()
    {
        if (!_isTransfer && _categoryId == 0)
        {
            _message = "Selecione uma categoria";
            _alertSeverity = Severity.Warning;
            return;
        }

        if (!decimal.TryParse(_amountText, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.GetCultureInfo("pt-BR"), out var parsedAmount))
            return;

        _amount = Math.Round(parsedAmount, 2);
        await ApiClient.UpdateTransactionAsync(
            Id,
            AccountState.SelectedAccountId ?? 0,
            _isTransfer ? null : _categoryId,
            _isTransfer ? _transferAccountId : null,
            _amount,
            _date,
            _description ?? string.Empty,
            _isTransfer ? (_transferDirection == TransferDirection.Send ? TransactionType.Expense : TransactionType.Income) : _type);

        Navigation.NavigateTo("/transactions");
    }

    private void Cancelar() => Navigation.NavigateTo("/transactions");

    private void FormatAmount(FocusEventArgs _)
    {
        if (decimal.TryParse(_amountText, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.GetCultureInfo("pt-BR"), out var v))
            _amountText = v.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"));
    }

    private void OnAmountInput(ChangeEventArgs e)
    {
        var digits = new string((e?.Value?.ToString() ?? string.Empty).Where(char.IsDigit).ToArray());
        if (string.IsNullOrEmpty(digits)) { _amountText = "0,00"; return; }
        if (digits.Length == 1) digits = "0" + digits;
        _amountText = (long.Parse(digits) / 100m).ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"));
    }

    private async void HandleAccountChanged() => await InvokeAsync(() => Navigation.NavigateTo("/transactions"));
    public void Dispose() => AccountState.OnChange -= HandleAccountChanged;
}
