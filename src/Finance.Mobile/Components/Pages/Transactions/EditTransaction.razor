@page "/transactions/edit/{Id:int}"
@implements IDisposable
@using MudBlazor
@using Finance.Domain.Entities
@using Finance.Mobile.Services
@inject FinanceApiClient ApiClient
@inject NavigationManager Navigation
@inject TokenService TokenService

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4 management-page transfer-form-page">
    <MudStack Spacing="1" Class="mb-2">
        <MudText Typo="Typo.h5" Class="list-page-title">Editar lançamento</MudText>
        <MudText Typo="Typo.body2" Class="transfer-form-subtitle">@GetFormSubtitle()</MudText>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
    }
    else if (_transaction == null)
    {
        <MudAlert Severity="Severity.Error">Lançamento não encontrado.</MudAlert>
    }
    else
    {
        <MudPaper Elevation="0" Class="transfer-mode-card mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle2">Modo do lançamento</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@(_isTransfer ? "Transferência entre contas correntes" : GetPostingDescription())</MudText>
                </MudStack>
                <MudSwitch T="bool" @bind-Value="_isTransfer" Color="Color.Primary" Label="Transferência" />
            </MudStack>
        </MudPaper>

        <MudForm>
            @if (_isTransfer)
            {
                <MudPaper Elevation="0" Class="transfer-section-card mb-4">
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="TransferDirection" Label="Direção" @bind-Value="_transferDirection" Variant="Variant.Outlined" Required="true">
                                <MudSelectItem Value="TransferDirection.Send">Enviar</MudSelectItem>
                                <MudSelectItem Value="TransferDirection.Receive">Receber</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="int" Label="Conta de transferência" Value="_transferAccountId" ValueChanged="OnTransferAccountChanged" Variant="Variant.Outlined" Required="true" Disabled="@(!_availableTransferAccounts.Any())">
                                @foreach (var account in _availableTransferAccounts)
                                {
                                    <MudSelectItem Value="@account.Id">@account.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            }
            else
            {
                <MudPaper Elevation="0" Class="transfer-section-card mb-4">
                    <MudGrid>
                        <MudItem xs="12">
                            <MudSelect T="int" Label="Lançar em" Value="_postingAccountId" ValueChanged="OnPostingAccountChanged" Variant="Variant.Outlined" Required="true">
                                @foreach (var option in _postingAccountOptions)
                                {
                                    <MudSelectItem Value="@option.Id">@option.Name</MudSelectItem>
                                }
                            </MudSelect>
                            @if (!HasLinkedCreditCards)
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1 d-block">Nenhum cartão vinculado cadastrado. A edição será aplicada apenas na conta corrente selecionada.</MudText>
                            }
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="TransactionType" Label="Tipo" Value="_type" ValueChanged="OnTypeChanged" Variant="Variant.Outlined" Required="true" Disabled="@IsCreditCardPosting">
                                <MudSelectItem Value="TransactionType.Income">Receita</MudSelectItem>
                                <MudSelectItem Value="TransactionType.Expense">Despesa</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudAutocomplete T="Category"
                                             @key="_categoryAutocompleteKey"
                                             Label="Categoria"
                                             Value="_selectedCategory"
                                             ValueChanged="OnCategoryChanged"
                                             SearchFunc="SearchCategories"
                                             ToStringFunc="@(c => c?.Name ?? string.Empty)"
                                             CoerceText="true"
                                             ResetValueOnEmptyText="true"
                                             Variant="Variant.Outlined"
                                             Required="true"
                                             Dense="true"
                                             Disabled="@(!_categories.Any())" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            }

            <MudPaper Elevation="0" Class="transfer-section-card">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Valor" @bind-Value="_amountText" Variant="Variant.Outlined" Required="true" Adornment="Adornment.Start" AdornmentText="R$" @onblur="FormatAmount" @oninput="OnAmountInput" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Label="Data" Date="@_date" DateChanged="(date) => _date = date ?? DateTime.Now" Variant="Variant.Outlined" Required="true" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Label="Descrição" @bind-Value="_description" Variant="Variant.Outlined" Lines="3" />
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudStack Row="true" Spacing="1" Class="mt-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Salvar" Disabled="@(_saving || (_isTransfer && !_availableTransferAccounts.Any()))">
                    @if (_saving)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ms-2">Salvando...</MudText>
                    }
                    else
                    {
                        <MudText>Salvar alterações</MudText>
                    }
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancelar">Cancelar</MudButton>
            </MudStack>
        </MudForm>
    }

    @if (!string.IsNullOrEmpty(_message))
    {
        <MudAlert Severity="@_alertSeverity" Class="mt-4">@_message</MudAlert>
    }
</MudContainer>

@code {
    private enum TransferDirection { Send, Receive }

    [Parameter] public int Id { get; set; }
    [Inject] public AccountSelectionState AccountState { get; set; } = default!;

    private List<Category> _categories = new();
    private List<Category> _allCategories = new();
    private List<Account> _allAccounts = new();
    private List<Account> _postingAccountOptions = new();
    private List<Account> _availableTransferAccounts = new();
    private Finance.Mobile.Services.TransactionDto? _transaction;
    private int _categoryId;
    private Category? _selectedCategory;
    private int _postingAccountId;
    private int _transferAccountId;
    private decimal _amount;
    private string _amountText = "0,00";
    private DateTime _date = DateTime.Now;
    private string _description = "";
    private TransactionType _type = TransactionType.Expense;
    private bool _isTransfer;
    private TransferDirection _transferDirection = TransferDirection.Send;
    private string _message = "";
    private Severity _alertSeverity = Severity.Info;
    private bool _loading = true;
    private bool _saving;
    private int _categoryAutocompleteKey;

    private bool IsCreditCardPosting => _postingAccountOptions.FirstOrDefault(a => a.Id == _postingAccountId)?.Type == AccountType.CreditCard;
    private bool HasLinkedCreditCards => _postingAccountOptions.Any(a => a.Type == AccountType.CreditCard);

    protected override async Task OnInitializedAsync()
    {
        AccountState.OnChange += HandleAccountChanged;
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;

        try
        {
            var token = await TokenService.GetTokenAsync();
            if (string.IsNullOrEmpty(token))
            {
                Navigation.NavigateTo("/login");
                return;
            }

            ApiClient.SetBearerToken(token);
            _allAccounts = AccountState.AllAccounts.Any() ? AccountState.AllAccounts.ToList() : await ApiClient.GetAccountsAsync();
            _allCategories = await ApiClient.GetCategoriesAsync();
            _transaction = await ApiClient.GetTransactionByIdAsync(Id);

            if (_transaction is null)
                return;

            _isTransfer = _transaction.TransferAccountId.HasValue;
            _amount = _transaction.Amount;
            _amountText = _amount.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"));
            _date = _transaction.Date;
            _description = _transaction.Description ?? string.Empty;
            _type = _transaction.Type;
            _categoryId = _transaction.CategoryId ?? 0;
            _postingAccountId = _transaction.AccountId;
            _transferAccountId = _transaction.TransferAccountId ?? 0;
            _transferDirection = _type == TransactionType.Expense ? TransferDirection.Send : TransferDirection.Receive;

            var selectedRootAccountId = _transaction.ParentAccountId ?? (_transaction.AccountType == AccountType.Checking ? _transaction.AccountId : AccountState.SelectedAccountId) ?? 0;
            _postingAccountOptions = _allAccounts.Where(a => a.Id == selectedRootAccountId || (a.Type == AccountType.CreditCard && a.ParentAccountId == selectedRootAccountId)).OrderBy(a => a.Type).ThenBy(a => a.Name).ToList();
            _availableTransferAccounts = _allAccounts.Where(a => a.Type == AccountType.Checking && a.Id != selectedRootAccountId).OrderBy(a => a.Name).ToList();

            await RefreshCategoriesAsync();
            _selectedCategory = _categories.FirstOrDefault(c => c.Id == _categoryId) ?? _categories.FirstOrDefault();
            _categoryId = _selectedCategory?.Id ?? 0;
        }
        catch (Exception ex)
        {
            _message = $"Erro ao carregar dados: {ex.Message}";
            _alertSeverity = Severity.Error;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshCategoriesAsync()
    {
        var effectiveType = IsCreditCardPosting ? TransactionType.Expense : _type;
        _categories = _allCategories.Where(c => c.Type == effectiveType).ToList();
        _selectedCategory = _categories.FirstOrDefault(c => c.Id == _selectedCategory?.Id) ?? _categories.FirstOrDefault();
        _categoryId = _selectedCategory?.Id ?? 0;
        _categoryAutocompleteKey++;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnPostingAccountChanged(int value)
    {
        _postingAccountId = value;
        if (IsCreditCardPosting)
            _type = TransactionType.Expense;

        await RefreshCategoriesAsync();
    }

    private async Task OnTypeChanged(TransactionType value)
    {
        _type = value;
        await RefreshCategoriesAsync();
    }

    private Task<IEnumerable<Category>> SearchCategories(string value, CancellationToken cancellationToken)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<Category>>(_categories);

        return Task.FromResult<IEnumerable<Category>>(_categories.Where(c => c.Name.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private Task OnCategoryChanged(Category? category)
    {
        _selectedCategory = category;
        _categoryId = category?.Id ?? 0;
        return Task.CompletedTask;
    }

    private Task OnTransferAccountChanged(int value)
    {
        _transferAccountId = value;
        return Task.CompletedTask;
    }

    private async Task Salvar()
    {
        if (!_isTransfer && _categoryId == 0)
        {
            _message = "Selecione uma categoria.";
            _alertSeverity = Severity.Warning;
            return;
        }

        if (_isTransfer && _transferAccountId == 0)
        {
            _message = "Selecione a conta para transferência.";
            _alertSeverity = Severity.Warning;
            return;
        }

        if (!decimal.TryParse(_amountText, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.GetCultureInfo("pt-BR"), out var parsedAmount))
        {
            _message = "Valor inválido.";
            _alertSeverity = Severity.Error;
            return;
        }

        _amount = Math.Round(parsedAmount, 2);

        try
        {
            _saving = true;
            await ApiClient.UpdateTransactionAsync(
                Id,
                _isTransfer ? (_transaction?.ParentAccountId ?? AccountState.SelectedAccountId ?? 0) : _postingAccountId,
                _isTransfer ? null : _categoryId,
                _isTransfer ? _transferAccountId : null,
                _amount,
                _date,
                _description ?? string.Empty,
                _isTransfer ? (_transferDirection == TransferDirection.Send ? TransactionType.Expense : TransactionType.Income) : (IsCreditCardPosting ? TransactionType.Expense : _type));

            _message = "Lançamento atualizado com sucesso!";
            _alertSeverity = Severity.Success;
            await Task.Delay(300);
            Navigation.NavigateTo("/transactions");
        }
        catch (Exception ex)
        {
            _message = $"Erro ao atualizar lançamento: {ex.Message}";
            _alertSeverity = Severity.Error;
        }
        finally
        {
            _saving = false;
        }
    }

    private string GetPostingDescription() => IsCreditCardPosting
        ? "Despesa lançada em cartão vinculado"
        : HasLinkedCreditCards
            ? "Receita/Despesa na conta corrente"
            : "Receita/Despesa na conta corrente (sem cartões vinculados)";

    private string GetFormSubtitle() => HasLinkedCreditCards
        ? "Você pode ajustar lançamentos na conta selecionada ou em cartões vinculados."
        : "Nenhum cartão vinculado foi cadastrado. A edição será aplicada somente na conta corrente selecionada.";
    private void Cancelar() => Navigation.NavigateTo("/transactions");

    private void FormatAmount(FocusEventArgs _)
    {
        if (decimal.TryParse(_amountText, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.GetCultureInfo("pt-BR"), out var value))
            _amountText = value.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"));
    }

    private void OnAmountInput(ChangeEventArgs e)
    {
        var digits = new string((e?.Value?.ToString() ?? string.Empty).Where(char.IsDigit).ToArray());
        if (string.IsNullOrEmpty(digits)) { _amountText = "0,00"; return; }
        if (digits.Length == 1) digits = "0" + digits;
        _amountText = (long.Parse(digits) / 100m).ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"));
    }

    private async void HandleAccountChanged() => await InvokeAsync(() => Navigation.NavigateTo("/transactions"));
    public void Dispose() => AccountState.OnChange -= HandleAccountChanged;
}
