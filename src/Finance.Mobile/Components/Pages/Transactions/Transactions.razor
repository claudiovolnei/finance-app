@page "/transactions"
@implements IDisposable
@using MudBlazor
@using Finance.Domain.Entities
@using Finance.Mobile.Services
@inject FinanceApiClient ApiClient
@inject NavigationManager Navigation
@inject TokenService TokenService
@inject AccountSelectionState AccountState

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 management-page">
    <MonthYearNavigator CurrentLabel="@GetCurrentFilterLabel()" OnPrevious="PrevMonth" OnNext="NextMonth" />
    <MudGrid GutterSize="GutterSize.Small" AlignItems="Center">
        <MudItem xs="12" sm="12">
            <MudPaper Class="pa-4 card-center" Elevation="1">
                <MudText Typo="Typo.subtitle1">Saldo Atual</MudText>
                <MudText Typo="Typo.h5" Class="fluid-value" Color="_totalBalanceMonth > 0 ? Color.Success : Color.Error">@(string.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C}", _totalBalanceMonth))</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="6">
            <MudPaper Class="pa-4 card-center" Elevation="1">
                <MudText Typo="Typo.subtitle1">Receitas</MudText>
                <MudText Typo="Typo.h5" Class="fluid-value" Color="Color.Success">@(_transactions is null ? "-" : string.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C}", _totalIncomeMonth))</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="6">
            <MudPaper Class="pa-4 card-center" Elevation="1">
                <MudText Typo="Typo.subtitle1">Despesas</MudText>
                <MudText Typo="Typo.h5" Class="fluid-value" Color="Color.Error">@(_transactions is null ? "-" : string.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C}", _totalExpenseMonth))</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="entity-page-header">
        <MudText Typo="Typo.h4" Class="list-page-title transaction-title">Lançamentos</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.Add" Class="new-entity-button" OnClick="NavigateToAdd">Novo</MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
    }
    else if (_transactions == null || !_transactions.Any())
    {
        <MudAlert Severity="Severity.Info" Dense="true">Nenhum lançamento encontrado.</MudAlert>
    }
    else
    {
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2">@_transactions.Count lançamentos no período</MudText>

            @if (_incomeTransactions.Any())
            {
                <MudText Typo="Typo.subtitle2" Class="transaction-group-title transaction-group-title-income mb-1">Créditos</MudText>
                <MudList T="TransactionDto" Dense="true" Class="pa-0 mb-3">
                    @foreach (var tx in _incomeTransactions)
                    {
                        @TransactionRow(tx)
                    }
                </MudList>
            }

            @if (_expenseTransactions.Any())
            {
                <MudText Typo="Typo.subtitle2" Class="transaction-group-title transaction-group-title-expense mb-1">Débitos</MudText>
                <MudList T="TransactionDto" Dense="true" Class="pa-0">
                    @foreach (var tx in _expenseTransactions)
                    {
                        @TransactionRow(tx)
                    }
                </MudList>
            }
        </MudPaper>
    }

    @if (!string.IsNullOrEmpty(_message))
    {
        <MudAlert Severity="@_alertSeverity" Dense="true" Class="mt-3">@_message</MudAlert>
    }
</MudContainer>

@if (_isTransactionPanelVisible && _selectedTransaction is not null)
{
    <div class="transaction-detail-overlay" @onclick="CloseTransactionDialogAsync">
        <MudPaper Class="@GetTransactionPanelClass()" Elevation="6" @onclick:stopPropagation="true">
            <MudStack Spacing="3">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                    <MudText Typo="Typo.caption" Class="transaction-detail-subtitle">Resumo do lançamento</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" Size="Size.Small" OnClick="CloseTransactionDialogAsync" />
                </MudStack>

                <MudPaper Class="transaction-highlight-card" Elevation="0">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Valor da transação</MudText>
                            <MudText Typo="Typo.h5" Color="@GetTransactionColor(_selectedTransaction.Type)">@string.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C}", _selectedTransaction.Amount)</MudText>
                        </MudStack>
                        <MudChip T="string" Color="@GetTransactionColor(_selectedTransaction.Type)" Variant="Variant.Filled" Size="Size.Small">@(_selectedTransaction.Type == TransactionType.Income ? "Receita" : "Despesa")</MudChip>
                    </MudStack>
                </MudPaper>

                <MudGrid Class="transaction-detail-grid" GutterSize="GutterSize.Small">
                    <MudItem xs="12" sm="6">
                        <MudPaper Class="transaction-detail-item" Elevation="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Conta do lançamento</MudText>
                            <MudText Typo="Typo.body1">@_selectedTransaction.AccountName</MudText>
                        </MudPaper>
                    </MudItem>
                    @if (_selectedTransaction.IsCreditCardExpense)
                    {
                        <MudItem xs="12" sm="6">
                            <MudPaper Class="transaction-detail-item" Elevation="0">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Conta vinculada</MudText>
                                <MudText Typo="Typo.body1">@(_selectedTransaction.ParentAccountName ?? "-")</MudText>
                            </MudPaper>
                        </MudItem>
                    }
                    @if (!_selectedTransaction.TransactionAccountName.Equals("N/A"))
                    {
                        <MudItem xs="12" sm="6">
                            <MudPaper Class="transaction-detail-item" Elevation="0">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@(_selectedTransaction.Type == TransactionType.Income ? "Recebido da:" : "Enviado para:")</MudText>
                                <MudText Typo="Typo.body1">@_selectedTransaction.TransactionAccountName</MudText>
                            </MudPaper>
                        </MudItem>
                    }
                    <MudItem xs="12" sm="6">
                        <MudPaper Class="transaction-detail-item" Elevation="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Categoria</MudText>
                            <MudText Typo="Typo.body1">@_selectedTransaction.CategoryName</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudPaper Class="transaction-detail-item" Elevation="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Data</MudText>
                            <MudText Typo="Typo.body1">@_selectedTransaction.Date.ToString("dd/MM/yyyy")</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12">
                        <MudPaper Class="transaction-detail-item" Elevation="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Descrição</MudText>
                            <MudText Typo="Typo.body1">@(string.IsNullOrWhiteSpace(_selectedTransaction.Description) ? "Sem descrição informada" : _selectedTransaction.Description)</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudDivider />
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Referência da transação #@_selectedTransaction.Id</MudText>
            </MudStack>
        </MudPaper>
    </div>
}

@code {
    private List<TransactionDto>? _transactions;
    private bool _loading = true;
    private string _message = "";
    private Severity _alertSeverity = Severity.Info;
    private int? _filterYear;
    private int? _filterMonth;
    private DateTime _current = DateTime.Now;
    private decimal _totalBalanceMonth;
    private decimal _totalIncomeMonth;
    private decimal _totalExpenseMonth;
    private List<TransactionDto> _incomeTransactions = new();
    private List<TransactionDto> _expenseTransactions = new();
    private TransactionDto? _selectedTransaction;
    private bool _isTransactionDialogOpen;
    private bool _isTransactionPanelVisible;
    private const int TransactionPanelAnimationMs = 260;

    protected override async Task OnInitializedAsync()
    {
        AccountState.OnChange += HandleGlobalAccountChanged;

        var token = await TokenService.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        ApiClient.SetBearerToken(token);
        _filterYear = _current.Year;
        _filterMonth = _current.Month;

        await LoadTransactions();
    }

    private RenderFragment TransactionRow(TransactionDto tx) => @<>
        <MudListItem T="TransactionDto" Class="px-0" Button="true" OnClick="@(() => OpenTransactionDialog(tx))">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width:100%;">
                <MudStack Spacing="0" Style="min-width:0;">
                    <MudText Typo="Typo.body2" Class="list-primary-text">@tx.CategoryName</MudText>
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary list-secondary-text">@tx.Date.ToString("dd/MM/yyyy")</MudText>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@(tx.IsCreditCardExpense ? Color.Error : Color.Info)">@GetAccountChipLabel(tx)</MudChip>
                    </MudStack>
                </MudStack>

                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@tx.AccountName</MudText>
                    <MudChip T="string" Color="@(tx.Type == TransactionType.Income ? Color.Success : Color.Error)" Variant="Variant.Text" Size="Size.Small">@(tx.Type == TransactionType.Income ? "Crédito" : "Débito")</MudChip>
                    <MudText Typo="Typo.body2" Class="list-value-text" Color="@(tx.Type == TransactionType.Income ? Color.Success : Color.Error)">@tx.Amount.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</MudText>
                    <span @onclick:stopPropagation="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => NavigateToEdit(tx.Id))" />
                    </span>
                    <span @onclick:stopPropagation="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteTransaction(tx.Id))" />
                    </span>
                </MudStack>
            </MudStack>
        </MudListItem>
        <MudDivider />
    </>;

    private string GetCurrentFilterLabel() => _current.ToString("MMMM yyyy", new System.Globalization.CultureInfo("pt-BR"));

    private async Task PrevMonth()
    {
        _current = _current.AddMonths(-1);
        _filterYear = _current.Year;
        _filterMonth = _current.Month;
        await LoadTransactions();
    }

    private async Task NextMonth()
    {
        _current = _current.AddMonths(1);
        _filterYear = _current.Year;
        _filterMonth = _current.Month;
        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        try
        {
            _loading = true;
            _transactions = await ApiClient.GetTransactionsAsync(_filterYear, _filterMonth, AccountState.SelectedAccountId);
            _transactions = _transactions.OrderByDescending(t => t.Date).ThenByDescending(t => t.Id).ToList();
            _incomeTransactions = _transactions.Where(t => t.Type == TransactionType.Income).ToList();
            _expenseTransactions = _transactions.Where(t => t.Type == TransactionType.Expense).ToList();
            _totalBalanceMonth = _incomeTransactions.Sum(t => t.Amount) - _expenseTransactions.Sum(t => t.Amount);
            _totalIncomeMonth = _incomeTransactions.Sum(t => t.Amount);
            _totalExpenseMonth = _expenseTransactions.Sum(t => t.Amount);
        }
        catch (UnauthorizedAccessException)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        catch (Exception ex)
        {
            _message = $"Erro ao carregar lançamentos: {ex.Message}";
            _alertSeverity = Severity.Error;
        }
        finally
        {
            _loading = false;
        }
    }

    private void NavigateToAdd() => Navigation.NavigateTo("/transactions/add");
    private void NavigateToEdit(int id) => Navigation.NavigateTo($"/transactions/edit/{id}");

    private async Task DeleteTransaction(int id)
    {
        try
        {
            await ApiClient.DeleteTransactionAsync(id);
            _message = "Lançamento excluído com sucesso!";
            _alertSeverity = Severity.Success;
            await LoadTransactions();
        }
        catch (Exception ex)
        {
            _message = $"Erro ao excluir lançamento: {ex.Message}";
            _alertSeverity = Severity.Error;
        }
    }

    private string GetAccountChipLabel(TransactionDto transaction) => transaction.IsCreditCardExpense
        ? $"Cartão · {transaction.ParentAccountName}"
        : "Conta corrente";

    private void OpenTransactionDialog(TransactionDto transaction)
    {
        _selectedTransaction = transaction;
        _isTransactionPanelVisible = true;
        _isTransactionDialogOpen = true;
    }

    private async Task CloseTransactionDialogAsync()
    {
        _isTransactionDialogOpen = false;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(TransactionPanelAnimationMs);
        _isTransactionPanelVisible = false;
        _selectedTransaction = null;
    }

    private string GetTransactionPanelClass() => _isTransactionDialogOpen ? "transaction-detail-dialog transaction-detail-dialog-open" : "transaction-detail-dialog transaction-detail-dialog-close";
    private Color GetTransactionColor(TransactionType type) => type == TransactionType.Income ? Color.Success : Color.Error;

    private async void HandleGlobalAccountChanged()
    {
        _current = DateTime.Now;
        _filterYear = _current.Year;
        _filterMonth = _current.Month;
        await LoadTransactions();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() => AccountState.OnChange -= HandleGlobalAccountChanged;
}
